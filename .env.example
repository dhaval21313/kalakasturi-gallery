# =========================================================================
# KALA KASTURI ART GALLERY - FIREBASE LOCAL CONFIGURATION TEMPLATE
# =========================================================================
# Copy this file to `.env.local` and populate it with keys from your Google Firebase Console.
# Do NOT check `.env.local` into Git version control.

# 1. Google Firebase Web SDK Credentials
# Find these in Firebase Console > Project Settings > General > Your Apps (Web App config)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=kalakasturi-art-gallery.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=kalakasturi-art-gallery
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=kalakasturi-art-gallery.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=1:your_app_id_here

# 2. Database Controls
# Set to 'true' to allow dynamic DB seeding via /api/admin/seed in production (optional)
ENABLE_DB_SEED=false

# 3. WhatsApp Contact Settings (Dual-Checkout Integration)
NEXT_PUBLIC_WHATSAPP_NUMBER=+919876543210
